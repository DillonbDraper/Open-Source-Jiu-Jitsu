<Layouts.app flash={@flash}>
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Welcome to Open Source BJJ</h1>
    <.link navigate={~p"/techniques/new"} class="btn btn-primary">
      Add A Technique
    </.link>
  </div>

  <p class="text-lg text-center text-base-content/70">
    Curated collection of high-quality Brazilian Jiu-Jitsu instructional videos.
  </p>
</Layouts.app>
