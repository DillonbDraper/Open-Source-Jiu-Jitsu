{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "tidewave": {
      "type": "remote",
      "url": "http://127.0.0.1:4000/tidewave/mcp",
      "enabled": true
    }
  }
}
